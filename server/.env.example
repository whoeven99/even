PORT=3000
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Bill stage store TTL in milliseconds (default 30min)
BILL_STAGE_TTL_MS=1800000

# Azure Blob Storage
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=bill-stage-cache

# Azure Cosmos DB (SQL API)
AZURE_COSMOS_ENDPOINT=
AZURE_COSMOS_KEY=
AZURE_COSMOS_DATABASE=even
AZURE_COSMOS_CONTAINER=bill_stages
